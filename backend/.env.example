# ============================================================
# .env.example — Mẫu cấu hình môi trường
# Copy file này thành .env rồi điền giá trị thực
# KHÔNG commit file .env lên Git!
# ============================================================

# ── Bắt buộc ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
JWT_SECRET=your_jwt_secret_here
PORT=8000
# Webhook URL (cấu hình trên SePay, không phải biến env):
#   https://<domain-backend>/api/payments/sepay/webhook
#
# SEPAY_SECRET = Webhook Secret của ĐÚNG merchant SePay (cùng merchant với SEPAY_API_TOKEN)
# SEPAY_SECRETS = thêm secret merchant khác, cách nhau dấu phẩy
SEPAY_SECRET=your_webhook_secret_for_store_merchant
# SEPAY_SECRETS=secret_merchant_2,secret_merchant_3
SEPAY_API_TOKEN=your_sepay_user_api_token
# SEPAY_API_TOKENS=token_store_2
SEPAY_API_BASE_URL=https://my.sepay.vn
#
# QR POS: cấu hình trong app → Cài đặt cửa hàng (bank_id, bank_account, bank_account_name)
# Các biến dưới chủ yếu cho subscription / tham chiếu — nên khớp STK trên SePay:
SEPAY_ACCOUNT_NUMBER=0123456789
SEPAY_BANK_CODE=mb
SEPAY_ACCOUNT_NAME=TEN CHU TAI KHOAN
# SEPAY_ALLOW_INSECURE_WEBHOOK=true

# CORS (tuỳ chọn) 
# CORS_ORIGIN=https://pos247.store,https://www.pos247.store

# ── Cloudinary (upload ảnh) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Backup Configuration ───────────────────────────────────
# Bật/tắt backup tự động hằng ngày (mặc định: true)
BACKUP_SCHEDULE_DAILY=true

# Giờ chạy daily backup, 0-23 (mặc định: 1 = 01:00 AM)
BACKUP_DAILY_HOUR=1

# Bật backup thêm mỗi 4 tiếng (mặc định: false)
# Bật nếu hệ thống bận, RPO yêu cầu < 4h
BACKUP_SCHEDULE_HOURLY=false

# Số bản backup tối đa giữ lại (mặc định: 14 = 2 tuần)
BACKUP_MAX_COUNT=14
